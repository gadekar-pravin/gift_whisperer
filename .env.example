# Copy this file to `.env` and fill in your real keys.
# Do NOT commit the real .env to git.

# --- Gemini backend selection ---
# "aistudio" (default) — uses GEMINI_API_KEY for auth
# "vertexai"           — uses Application Default Credentials (ADC) for auth
# GEMINI_BACKEND=aistudio

# --- AI Studio backend (default) ---
# Get from https://aistudio.google.com/app/apikey  (free)
GEMINI_API_KEY=your_gemini_key_here

# --- Vertex AI backend ---
# Required when GEMINI_BACKEND=vertexai. Your GCP project ID.
# GOOGLE_CLOUD_PROJECT=my-gcp-project
# Optional: GCP region (defaults to us-central1)
# GOOGLE_CLOUD_LOCATION=us-central1
# Auth: run `gcloud auth application-default login` or use a service account.

# --- RapidAPI ---
# Get from https://rapidapi.com/letscrape-6bRBa3QguO5/api/real-time-amazon-data
# Free tier gives ~500 requests/month at the time of writing. Verify current quota when you sign up.
RAPIDAPI_KEY=your_rapidapi_key_here

# Optional: override the Gemini model (defaults to gemini-flash-latest)
# GEMINI_MODEL=gemini-flash-latest
