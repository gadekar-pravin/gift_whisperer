# Copy this file to `.env` and fill in your real keys.
# Do NOT commit the real .env to git.

# Get from https://aistudio.google.com/app/apikey  (free)
GEMINI_API_KEY=your_gemini_key_here

# Get from https://rapidapi.com/letscrape-6bRBa3QguO5/api/real-time-amazon-data
# Free tier gives ~500 requests/month at the time of writing. Verify current quota when you sign up.
RAPIDAPI_KEY=your_rapidapi_key_here
